<?xml version="1.0"?>
<ruleset name="Custom Rules"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 http://pmd.sourceforge.net/ruleset/2.0.0/ruleset_2_0_0.xsd"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <description>
        Profil PMD du projet location-voitures.
        Active best-practices + error-prone + performance, en excluant les
        faux positifs systemiques au stack Spring Boot + Lombok + SLF4J + JPA.
    </description>

    <rule ref="category/java/bestpractices.xml">
        <!-- SLF4J 2.x avec placeholders {} est deja lazy : pas besoin de
             guard log.isXxxEnabled() avant chaque log -->
        <exclude name="GuardLogStatement"/>
        <!-- Faux positif : Utilisateur est abstract pour la strategie JPA
             JOINED, pas besoin de methode abstraite. -->
        <exclude name="AbstractClassWithoutAbstractMethod"/>
    </rule>

    <rule ref="category/java/errorprone.xml">
        <!-- Beaucoup de doublons sont des messages d'erreur en francais
             (PMD 7 a deplace cette regle en errorprone) -->
        <exclude name="AvoidDuplicateLiterals"/>
        <!-- Faux positif sur les emails ASCII : les locales turques (i/I)
             n'affectent pas nos identifiants. -->
        <exclude name="UseLocaleWithCaseConversions"/>
        <!-- Faux positif : DataInitializer / TestVoituresInitializer ne
             sont pas des classes de test malgre leur suffixe. -->
        <exclude name="TestClassWithoutTestCases"/>
    </rule>

    <rule ref="category/java/performance.xml">
        <!-- Faux positif avec @Builder.Default de Lombok : l'initialiseur
             est lu par Lombok pour le builder, il n'est pas redondant. -->
        <exclude name="RedundantFieldInitializer"/>
    </rule>
</ruleset>
